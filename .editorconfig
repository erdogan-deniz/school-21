# EditorConfig — top-level repo conventions, picked up by most IDEs.
# https://editorconfig.org/
root = true

[*]
charset                  = utf-8
indent_style             = space
indent_size              = 4
end_of_line              = lf
trim_trailing_whitespace = true
insert_final_newline     = true

# C / C++ — Google style is 2-space indent.
[*.{c,h,cc,cpp,cxx,hh,hpp,hxx}]
indent_size = 2

# YAML and YAML-adjacent — 2-space indent (canonical).
[*.{yml,yaml}]
indent_size = 2

# Markdown — keep trailing whitespace (used for hard line breaks).
[*.md]
trim_trailing_whitespace = false

# Makefiles — TABs are syntactic.
[Makefile]
indent_style = tab

[*.mk]
indent_style = tab

# Windows-only scripts.
[*.{bat,cmd,ps1}]
end_of_line = crlf
