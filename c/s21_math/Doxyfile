# Doxyfile for c/s21_math — curated subset of doxygen -g defaults.
# Used by .github/workflows/docs.yml; if absent, the workflow auto-
# generates a default Doxyfile and patches it. This file overrides
# that fallback with project-specific content.
#
# To regenerate locally:
#     cd c/s21_math && doxygen Doxyfile && open docs/api/html/index.html

# --- Project ---
PROJECT_NAME           = "s21_math"
PROJECT_BRIEF          = "Own implementation of the C standard math.h library, validated against libcheck."
PROJECT_NUMBER         = "1.0"
OUTPUT_DIRECTORY       = docs/api
OUTPUT_LANGUAGE        = English

# --- Input ---
INPUT                  = src/
RECURSIVE              = YES
FILE_PATTERNS          = *.c *.h
EXCLUDE_PATTERNS       = */test_html/* */gcov_obj/* */obj/* unit_test.c

# --- Extraction ---
# School 21 codebase has no Doxygen comments yet, so EXTRACT_ALL = YES
# documents every symbol from its signature alone. Once the deliberate
# Doxygen-comment pass lands, this can flip back to NO for tighter docs.
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
HIDE_UNDOC_MEMBERS     = NO

# --- Output formats ---
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
HTML_DYNAMIC_MENUS     = YES
HTML_EXTRA_STYLESHEET  =
DISABLE_INDEX          = NO

# --- Source browser ---
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# --- Diagrams (require Graphviz on PATH; CI installs it). ---
HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES

# --- Quiet operation ---
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_NO_PARAMDOC       = NO

# --- Optimisation ---
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES

# --- Tag file (cross-referencing across sibling subprojects) ---
GENERATE_TAGFILE       = docs/api/s21_math.tag
