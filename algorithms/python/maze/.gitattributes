# ──────────────────────────────────────────────────────────────────────────────
# Default: все текстовые файлы нормализуются до LF
# ──────────────────────────────────────────────────────────────────────────────
* text=auto eol=lf

# ──────────────────────────────────────────────────────────────────────────────
# Source code
# ──────────────────────────────────────────────────────────────────────────────
*.py     text eol=lf diff=python
*.toml   text eol=lf
*.ini    text eol=lf

# ──────────────────────────────────────────────────────────────────────────────
# Data
# ──────────────────────────────────────────────────────────────────────────────
*.txt    text eol=lf

# ──────────────────────────────────────────────────────────────────────────────
# Web
# ──────────────────────────────────────────────────────────────────────────────
*.html   text eol=lf
*.json   text eol=lf

# ──────────────────────────────────────────────────────────────────────────────
# Docs & config
# ──────────────────────────────────────────────────────────────────────────────
*.md     text eol=lf
Makefile text eol=lf

# ──────────────────────────────────────────────────────────────────────────────
# Binary
# ──────────────────────────────────────────────────────────────────────────────
*.png    binary
*.jpg    binary
*.ico    binary

# ──────────────────────────────────────────────────────────────────────────────
# Export (git archive / release tarballs)
# ──────────────────────────────────────────────────────────────────────────────
.gitignore        export-ignore
.gitattributes    export-ignore
Makefile          export-ignore
docs/             export-ignore
tests/            export-ignore
content/          export-ignore
